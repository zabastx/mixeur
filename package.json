{
	"version": "0.28.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"preview": "vite preview",
		"build": "vite build",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"prepare": "husky",
		"test": "vitest",
		"test:unit": "vitest run",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:debug": "playwright test --debug",
		"types:generate": "bun run plugins/run-gen.ts",
		"types:check": "vue-tsc --build"
	},
	"lint-staged": {
		"src/**/*.{js,ts,vue}": [
			"eslint --fix",
			"prettier --write"
		],
		"src/**/*.css": "prettier --write"
	},
	"dependencies": {
		"@jaames/iro": "^5.5.2",
		"@tailwindcss/vite": "^4.3.1",
		"@vueuse/core": "^14.3.0",
		"@msgpack/msgpack": "^3.1.3",
		"pinia": "^3.0.4",
		"reka-ui": "^2.9.10",
		"tailwindcss": "^4.3.1",
		"three": "^0.184.0",
		"three-mesh-bvh": "^0.9.10",
		"three-viewport-gizmo": "^2.2.0",
		"vue": "^3.5.38"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@pinia/testing": "^1.0.3",
		"@playwright/test": "^1.61.0",
		"@testing-library/user-event": "^14.6.1",
		"@testing-library/vue": "^8.1.0",
		"@tsconfig/node22": "^22.0.5",
		"@types/gl": "^6.0.5",
		"@types/node": "^25.9.4",
		"@types/three": "^0.184.1",
		"@vitejs/plugin-vue": "^6.0.7",
		"@vitest/coverage-v8": "4.1.9",
		"@vue/test-utils": "^2.4.11",
		"@vue/tsconfig": "^0.9.1",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-vue": "^10.9.2",
		"gl": "^8.1.6",
		"globals": "^17.6.0",
		"happy-dom": "^20.10.6",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"prettier": "3.8.4",
		"prettier-plugin-classnames": "^0.10.2",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"tailwind-scrollbar": "^4.0.2",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.61.1",
		"unplugin-vue-components": "^32.1.0",
		"vite": "^8.0.16",
		"vite-plugin-pwa": "^1.3.0",
		"vitest": "^4.1.9",
		"vue-eslint-parser": "^10.4.1",
		"vue-tsc": "^3.3.5"
	},
	"trustedDependencies": [
		"@tailwindcss/oxide",
		"esbuild",
		"gl",
		"vue-demi"
	]
}
